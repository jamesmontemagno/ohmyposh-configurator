  {
    "type": "nba",
    "name": "NBA",
    "description": "Synced from upstream docs for the nba segment.",
    "icon": "ui-globe",
    "defaultTemplate": "\udb82\udc06 {{ .HomeTeam}}{{ if .HasStats }} ({{.HomeTeamWins}}-{{.HomeTeamLosses}}){{ end }}{{ if .Started }}:{{.HomeScore}}{{ end }} vs {{ .AwayTeam}}{{ if .HasStats }} ({{.AwayTeamWins}}-{{.AwayTeamLosses}}){{ end }}{{ if .Started }}:{{.AwayScore}}{{ end }} | {{ if not .Started }}{{.GameDate}} | {{ end }}{{.Time}}",
    "defaultForeground": "#ffffff",
    "defaultBackground": "#00ACC1",
    "previewText": "🏀 BOS (61-21):102 vs NYK (50-32):99 | 00:42",
    "properties": [
      {
        "name": ".HomeTeam",
        "type": "string",
        "description": "home team for the upcoming game"
      },
      {
        "name": ".AwayTeam",
        "type": "string",
        "description": "away team for the upcoming game"
      },
      {
        "name": ".Time",
        "type": "string",
        "description": "time (EST) that the upcoming game will start"
      },
      {
        "name": ".GameDate",
        "type": "string",
        "description": "date the game will happen"
      },
      {
        "name": ".StartTimeUTC",
        "type": "string",
        "description": "time (UTC) the game will start"
      },
      {
        "name": ".GameStatus",
        "type": "integer",
        "description": "integer, 1 = scheduled, 2 = in progress, 3 = finished"
      },
      {
        "name": ".HomeScore",
        "type": "int",
        "description": "score of the home team"
      },
      {
        "name": ".AwayScore",
        "type": "int",
        "description": "score of the away team"
      },
      {
        "name": ".HomeTeamWins",
        "type": "int",
        "description": "number of wins the home team currently has for the season"
      },
      {
        "name": ".HomeTeamLosses",
        "type": "int",
        "description": "number of losses the home team currently has for the season"
      },
      {
        "name": ".AwayTeamWins",
        "type": "int",
        "description": "number of wins the away team currently has for the season"
      },
      {
        "name": ".AwayTeamLosses",
        "type": "int",
        "description": "number of losses the away team currently has for the season"
      },
      {
        "name": ".Started",
        "type": "boolean",
        "description": "if the game was started or not"
      },
      {
        "name": ".HasStats",
        "type": "boolean",
        "description": "if the game has game stats or not"
      }
    ],
    "options": [
      {
        "name": "team",
        "type": "string",
        "default": "",
        "description": "tri-code for the NBA team you want to get data for"
      },
      {
        "name": "days_offset",
        "type": "int",
        "default": 8,
        "description": "how many days in advance you wish to see that information for"
      },
      {
        "name": "http_timeout",
        "type": "int",
        "default": 20,
        "description": "How long do you want to wait before you want to see your prompt more than your sugar? I figure a half second is a good default"
      }
    ]
  },
